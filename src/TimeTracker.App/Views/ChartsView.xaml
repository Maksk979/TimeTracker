<UserControl x:Class="TimeTracker.App.Views.ChartsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="500" d:DesignWidth="860">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Графики за сегодня" Style="{StaticResource H1Text}" VerticalAlignment="Center"/>
            <Button Grid.Column="1" Content="Обновить" Style="{StaticResource SecondaryButton}"
                    Command="{Binding LoadCommand}" VerticalAlignment="Center"/>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="1"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardBorder}" Margin="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="По категориям" Style="{StaticResource H2Text}" Margin="0,0,0,12"/>
                    <lvc:PieChart Grid.Row="1"
                                  Series="{Binding CategoryPieSeries}"
                                  LegendPosition="Right"
                                  AnimationsSpeed="00:00:0.5"/>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardBorder}" Margin="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="По часам" Style="{StaticResource H2Text}" Margin="0,0,0,12"/>
                    <lvc:CartesianChart Grid.Row="1"
                                        Series="{Binding HourlyBarSeries}"
                                        XAxes="{Binding HourlyXAxes}"
                                        AnimationsSpeed="00:00:0.5"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
