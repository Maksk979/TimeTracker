<UserControl x:Class="TimeTracker.App.Views.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="550" d:DesignWidth="860">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Отчёты" Style="{StaticResource H1Text}" Margin="0,0,0,20"/>

        <Border Grid.Row="1" Style="{StaticResource CardBorder}" Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="С:" Style="{StaticResource CaptionText}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <DatePicker Grid.Column="1" SelectedDate="{Binding DateFrom}" Width="150" Margin="0,0,16,0"/>
                <TextBlock Grid.Column="2" Text="По:" Style="{StaticResource CaptionText}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <DatePicker Grid.Column="3" SelectedDate="{Binding DateTo}" Width="150" Margin="0,0,16,0"/>
                <Button Grid.Column="4" Content="Сформировать" Style="{StaticResource PrimaryButton}" Margin="0,0,16,0"
                        Command="{Binding GenerateCommand}"/>
                <StackPanel Grid.Column="5" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Style="{StaticResource CardBorder}" Padding="12,6" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Активное: " Style="{StaticResource CaptionText}"/>
                            <TextBlock Text="{Binding TotalActiveTime}" Style="{StaticResource BodyText}" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource CardBorder}" Padding="12,6" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Простой: " Style="{StaticResource CaptionText}"/>
                            <TextBlock Text="{Binding TotalIdleTime}" Style="{StaticResource BodyText}" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource CardBorder}" Padding="12,6">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Сессий: " Style="{StaticResource CaptionText}"/>
                            <TextBlock Text="{Binding TotalSessions}" Style="{StaticResource BodyText}" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="1"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardBorder}" Margin="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="По категориям" Style="{StaticResource H2Text}" Margin="0,0,0,12"/>
                    <lvc:PieChart Grid.Row="1"
                                  Series="{Binding CategoryPieSeries}"
                                  LegendPosition="Right"
                                  AnimationsSpeed="00:00:0.5"/>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardBorder}" Margin="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="По дням" Style="{StaticResource H2Text}" Margin="0,0,0,12"/>
                    <lvc:CartesianChart Grid.Row="1"
                                        Series="{Binding DailyBarSeries}"
                                        XAxes="{Binding DailyXAxes}"
                                        YAxes="{Binding DailyYAxes}"
                                        AnimationsSpeed="00:00:0.5"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
