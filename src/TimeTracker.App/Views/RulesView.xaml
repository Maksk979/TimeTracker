<UserControl x:Class="TimeTracker.App.Views.RulesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:entities="clr-namespace:TimeTracker.Core.Storage.Entities;assembly=TimeTracker.Core"
             mc:Ignorable="d"
             d:DesignHeight="500" d:DesignWidth="860">
    <UserControl.Resources>
        <ObjectDataProvider x:Key="FieldTypes" MethodName="GetValues" ObjectType="{x:Type entities:RuleFieldType}"/>
        <ObjectDataProvider x:Key="MatchTypes" MethodName="GetValues" ObjectType="{x:Type entities:RuleMatchType}"/>
    </UserControl.Resources>
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Правила и категории" Style="{StaticResource H1Text}" VerticalAlignment="Center"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="↻ Обновить" Style="{StaticResource PrimaryButton}" Margin="0,0,8,0"
                        Command="{Binding LoadCommand}"/>
                <Button Content="Сохранить" Style="{StaticResource PrimaryButton}"
                        Command="{Binding SaveCommand}"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240"/>
                <ColumnDefinition Width="1"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardBorder}" Margin="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="КАТЕГОРИИ" Style="{StaticResource CaptionText}" Margin="0,0,0,8"/>
                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding Categories}"
                             SelectedItem="{Binding SelectedCategory}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Icon}" FontSize="14" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding Name}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,12,0,0">
                        <Button Content="+ Добавить" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0"
                                Command="{Binding AddCategoryCommand}"/>
                        <Button Content="Удалить" Style="{StaticResource SecondaryButton}"
                                Command="{Binding DeleteCategoryCommand}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardBorder}" Margin="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="ПРАВИЛА" Style="{StaticResource CaptionText}" Margin="0,0,0,8"/>
                    <DataGrid Grid.Row="1"
                              x:Name="RulesDataGrid"
                              ItemsSource="{Binding Rules}"
                              AutoGenerateColumns="False"
                              IsReadOnly="False"
                              SelectionMode="Single">
                        <DataGrid.Columns>
                            <DataGridComboBoxColumn Header="ПОЛЕ" Width="120"
                                                    SelectedItemBinding="{Binding FieldType}"
                                                    ItemsSource="{Binding Source={StaticResource FieldTypes}}"/>
                            <DataGridComboBoxColumn Header="ТИП" Width="120"
                                                    SelectedItemBinding="{Binding MatchType}"
                                                    ItemsSource="{Binding Source={StaticResource MatchTypes}}"/>
                            <DataGridTextColumn Header="ШАБЛОН" Binding="{Binding Pattern, UpdateSourceTrigger=LostFocus}" Width="*"/>
                            <DataGridTextColumn Header="ПРИОР." Binding="{Binding Priority, UpdateSourceTrigger=LostFocus}" Width="70"/>
                            <DataGridCheckBoxColumn Header="ВКЛ" Binding="{Binding IsEnabled}" Width="50"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,12,0,0">
                        <Button Content="+ Правило" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0"
                                Command="{Binding AddRuleCommand}"/>
                        <Button Content="− Удалить правило" Style="{StaticResource SecondaryButton}"
                                Command="{Binding DeleteSelectedRuleCommand}"
                                CommandParameter="{Binding ElementName=RulesDataGrid, Path=SelectedItem}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
