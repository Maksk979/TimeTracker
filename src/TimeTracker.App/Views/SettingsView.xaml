<UserControl x:Class="TimeTracker.App.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="400" d:DesignWidth="500">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Настройки" Style="{StaticResource H1Text}" Margin="0,0,0,20"/>

        <Border Grid.Row="1" Style="{StaticResource CardBorder}" Margin="0">
            <StackPanel>
                <TextBlock Text="ИНТЕРВАЛ ОПРОСА (МС)" Style="{StaticResource CaptionText}" Margin="0,0,0,6"/>
                <TextBox Text="{Binding PollIntervalMs}" Style="{StaticResource FieldTextBox}" Width="200"
                         HorizontalAlignment="Left" Margin="0,0,0,20"/>

                <TextBlock Text="ПОРОГ ПРОСТОЯ (СЕК)" Style="{StaticResource CaptionText}" Margin="0,0,0,6"/>
                <TextBox Text="{Binding IdleThresholdSeconds}" Style="{StaticResource FieldTextBox}" Width="200"
                         HorizontalAlignment="Left" Margin="0,0,0,20"/>

                <TextBlock Text="МИНИМАЛЬНАЯ ДЛИТЕЛЬНОСТЬ СЕССИИ (СЕК)" Style="{StaticResource CaptionText}" Margin="0,0,0,6"/>
                <TextBox Text="{Binding MinSessionSeconds}" Style="{StaticResource FieldTextBox}" Width="200"
                         HorizontalAlignment="Left" Margin="0,0,0,20"/>

                <CheckBox Content="Сохранять заголовки окон" IsChecked="{Binding StoreWindowTitles}"
                          Style="{StaticResource FieldCheckBox}" Margin="0,0,0,24"/>

                <Button Content="Сохранить" Style="{StaticResource PrimaryButton}"
                        Command="{Binding SaveCommand}" HorizontalAlignment="Left"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
